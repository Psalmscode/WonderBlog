<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sign In — WOnderBlog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
  <div class="auth-page">
    <div class="auth-bg-orb orb-1"></div>
    <div class="auth-bg-orb orb-2"></div>

    <button class="icon-btn theme-toggle-auth" id="themeToggle" title="Toggle theme">
      <svg class="icon-moon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
      <svg class="icon-sun" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>

    <div class="auth-card fade-up">
      <div class="auth-logo">WonderBlog</div>
      <div class="auth-gold-line"></div>
      <p class="auth-sub">A refined space for ideas, stories, and insights.<br/>Choose how you'd like to enter.</p>

      <div class="choice-grid">
        <a href="/admin" class="choice-card">
          <div class="choice-icon">⬡</div>
          <div class="choice-label">Admin</div>
          <div class="choice-desc">Full control — manage all posts, users, and settings</div>
        </a>
        <a href="/login" class="choice-card">
          <div class="choice-icon">◈</div>
          <div class="choice-label">Reader / Writer</div>
          <div class="choice-desc">Browse posts, create and manage your own content</div>
        </a>
      </div>

      <div class="auth-hint">
        Demo admin: <strong>Wonder / Blogger</strong><br/>
        Demo user: create an account or use existing credentials
      </div>
    </div>
  </div>
  <script src="/js/script.js"></script>
</body>
</html>
