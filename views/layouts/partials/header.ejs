<header class="header" id="siteHeader">
  <div class="header-inner wrap">
    <a href="/" class="logo">
      <span class="logo-dot"></span>
      WonderBlog
    </a>

    <nav class="nav" id="desktopNav">
      <a href="/" class="nav-link <%= locals.activePage === 'home' ? 'active' : '' %>">Home</a>
      <a href="/posts" class="nav-link <%= locals.activePage === 'posts' ? 'active' : '' %>">Posts</a>
      <a href="/about" class="nav-link <%= locals.activePage === 'about' ? 'active' : '' %>">About</a>
      <a href="/contact" class="nav-link <%= locals.activePage === 'contact' ? 'active' : '' %>">Contact</a>
      <% if (locals.user) { %>
        <a href="<%= locals.user.userType === 'admin' ? '/admin/dashboard' : '/dashboard' %>" class="nav-link">
          <%= locals.user.userType === 'admin' ? 'Dashboard' : 'My Posts' %>
        </a>
        <a href="<%= locals.user.userType === 'admin' ? '/admin/add-post' : '/user/add-post' %>" class="nav-link nav-link--gold">+ New Post</a>
      <% } %>
    </nav>

    <div class="header-actions">
      <div class="search-wrap">
        <form action="/" method="GET" class="search-form">
          <span class="search-icon">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <input type="text" name="search" class="search-input" placeholder="Search posts…" value="<%= locals.search || '' %>"/>
        </form>
      </div>

      <button class="icon-btn" id="themeToggle" title="Toggle theme" aria-label="Toggle dark mode">
        <svg class="icon-moon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
        <svg class="icon-sun" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>

      <% if (locals.user) { %>
        <div class="user-chip">
          <div class="user-avatar"><%= locals.user.username.charAt(0).toUpperCase() %></div>
          <span><%= locals.user.username %></span>
          <span class="role-badge"><%= locals.user.userType %></span>
        </div>
        <a href="/logout" class="icon-btn" title="Logout">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
      <% } else { %>
        <a href="/login-choice" class="btn-primary btn-sm">Sign In</a>
      <% } %>

      <button class="icon-btn mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <button class="mobile-close" id="mobileClose">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <a href="/" class="mobile-nav-link">Home</a>
  <a href="/posts" class="mobile-nav-link">Posts</a>
  <a href="/about" class="mobile-nav-link">About</a>
  <a href="/contact" class="mobile-nav-link">Contact</a>
  <% if (locals.user) { %>
    <a href="<%= locals.user.userType === 'admin' ? '/admin/dashboard' : '/dashboard' %>" class="mobile-nav-link">Dashboard</a>
    <a href="/logout" class="mobile-nav-link" style="color:var(--ink-3)">Logout</a>
  <% } else { %>
    <a href="/login-choice" class="mobile-nav-link" style="color:var(--gold)">Sign In</a>
  <% } %>
</div>
