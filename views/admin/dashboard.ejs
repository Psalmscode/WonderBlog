<div class="wrap dashboard fade-up">
  <div class="dashboard-header">
    <div class="dashboard-header-inner">
      <div>
        <h1 class="dashboard-title">Admin Dashboard</h1>
        <p class="dashboard-sub">Welcome back, <strong><%= locals.username || 'Admin' %></strong> — manage all content below</p>
      </div>
      <a href="/admin/add-post" class="btn-primary" style="display:flex;align-items:center;gap:6px">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Post
      </a>
    </div>
  </div>

  <div class="stats-row fade-up" style="animation-delay:0.1s">
    <div class="stat-card"><div class="stat-card-num"><%= locals.stats ? stats.totalPosts : data.length %></div><div class="stat-card-label">Total Posts</div></div>
    <div class="stat-card"><div class="stat-card-num"><%= locals.stats ? stats.authors : '—' %></div><div class="stat-card-label">Authors</div></div>
    <div class="stat-card"><div class="stat-card-num"><%= locals.stats ? stats.categories : '—' %></div><div class="stat-card-label">Categories</div></div>
    <div class="stat-card"><div class="stat-card-num"><%= locals.stats ? stats.featured : '—' %></div><div class="stat-card-label">Featured</div></div>
  </div>

  <div class="table-wrap fade-up" style="animation-delay:0.2s">
    <table class="posts-table">
      <thead>
        <tr>
          <th>Title</th><th>Category</th><th>Author</th><th>Date</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% data.forEach(post => { %>
          <tr>
            <td><a href="/post/<%= post._id %>" class="table-title"><%= post.title %></a></td>
            <td><span class="table-cat-badge"><%= post.category %></span></td>
            <td><%= post.author %></td>
            <td><%= post.createdAt ? post.createdAt.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—' %></td>
            <td>
              <div class="table-actions">
                <a href="/post/<%= post._id %>" class="tbl-btn" title="View">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
                <a href="/admin/edit-post/<%= post._id %>" class="tbl-btn" title="Edit">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </a>
                <form method="POST" action="/admin/delete-post/<%= post._id %>?_method=DELETE" style="display:inline" onsubmit="return confirm('Delete this post?')">
                  <button type="submit" class="tbl-btn tbl-btn--red" title="Delete">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
        <% if (!data.length) { %>
          <tr><td colspan="5" style="text-align:center;padding:40px;color:var(--ink-2)">No posts yet. <a href="/admin/add-post" style="color:var(--gold)">Create the first one →</a></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
