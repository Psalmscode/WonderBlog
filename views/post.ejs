<div class="post-detail wrap fade-in">
  <a href="/" class="back-btn">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Back to Posts
  </a>

  <div class="post-detail-header">
    <div class="post-detail-cat">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      <%= data.category %>
    </div>
    <h1 class="post-detail-title"><%= data.title %></h1>
    <div class="post-detail-meta">
      <div class="post-detail-author">
        <div class="post-detail-av"><%= data.author.charAt(0).toUpperCase() %></div>
        <div>
          <div class="post-detail-av-name"><%= data.author %></div>
          <div class="post-detail-av-role"><%= data.userType === 'admin' ? 'Admin' : 'Writer' %></div>
        </div>
      </div>
      <div class="post-detail-divider"></div>
      <div class="post-detail-stat">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <%= data.readTime || '5 min read' %>
      </div>
      <div class="post-detail-stat">
        <%= data.createdAt ? data.createdAt.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) : '' %>
      </div>
    </div>
    <div class="post-detail-line"></div>
  </div>

  <div class="post-detail-body">
    <%- data.content.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br/>').replace(/^(.)/,'<p>$1').replace(/(.)\s*$/,'$1</p>') %>
  </div>

  <% if (data.tags && data.tags.length) { %>
    <div class="post-tags">
      <% data.tags.forEach(tag => { %>
        <span class="post-tag">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg>
          <%= tag %>
        </span>
      <% }) %>
    </div>
  <% } %>

  <% if (locals.user && (locals.user.userType === 'admin' || locals.user.userId == data.userId)) { %>
    <div class="post-actions-bar">
      <a href="<%= locals.user.userType === 'admin' ? '/admin/edit-post/' + data._id : '/user/edit-post/' + data._id %>" class="btn-edit">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Post
      </a>
      <form method="POST" action="<%= locals.user.userType === 'admin' ? '/admin/delete-post/' + data._id : '/user/delete-post/' + data._id %>?_method=DELETE" style="display:inline" onsubmit="return confirm('Delete this post?')">
        <button type="submit" class="btn-danger">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Delete
        </button>
      </form>
    </div>
  <% } %>

  <% if (locals.related && locals.related.length > 0) { %>
    <div class="related-posts">
      <h3 class="related-title">More in <%= data.category %></h3>
      <div class="related-grid">
        <% related.forEach(rp => { %>
          <a href="/post/<%= rp._id %>" class="related-card">
            <div class="related-cat"><%= rp.category %></div>
            <div class="related-card-title"><%= rp.title %></div>
            <div class="related-card-date"><%= rp.createdAt ? rp.createdAt.toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '' %></div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>
